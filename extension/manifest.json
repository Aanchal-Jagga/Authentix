{
  "name": "Authentix",
  "description": "Real-time AI deepfake + AI-generated image detection while browsing.",
  "version": "1.1.0",
  "manifest_version": 3,
  "permissions": ["activeTab", "contextMenus", "storage", "scripting"],
  "host_permissions": ["http://127.0.0.1:8000/*"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
